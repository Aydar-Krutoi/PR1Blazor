@page "/profile"
@using PR1Blazor.ApiRequest
@using PR1Blazor.ApiRequest.Models
@using PR1Blazor.ApiRequest.Models.Services
@inject NavigationManager Navigation
@inject UserService UserService

<PageTitle>Профиль пользователя</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 text-primary">Профиль</h4>
                </div>
                
                <div class="card-body">
                    @if (UserService.CurrentUser?.user != null)
                    {
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <strong>Имя:</strong>
                                <span>@UserService.CurrentUser.user.Name</span>
                            </li>
                            
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <strong>Email / Логин:</strong>
                                <span>@UserService.CurrentUser.user.Login</span>
                            </li>
                            
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <strong>Роль:</strong>
                                <span class="badge bg-info text-dark">
                                    @(UserService.CurrentUser.user.RoleId == 1 ? "Администратор" : "Пользователь")
                                </span>
                            </li>

                            <li class="list-group-item px-0">
                                <strong>О себе:</strong>
                                <p class="text-muted small mt-2">
                                    @(string.IsNullOrWhiteSpace(UserService.CurrentUser.user.Descrioption) 
                                        ? "Описание не заполнено." 
                                        : UserService.CurrentUser.user.Descrioption)
                                </p>
                            </li>
                        </ul>

                        <div class="mt-4 text-end">
                            <a class="btn btn-primary" href="/movie">
                               фильмы
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            Данные пользователя не найдены. Пожалуйста, авторизуйтесь.
                        </div>
                    }
                </div>
                
                <div class="card-footer bg-light text-center">
                    <small class="text-muted">ID системы: #@UserService.CurrentUser?.user?.id_User</small>
                </div>
            </div>

        </div>
    </div>
</div>