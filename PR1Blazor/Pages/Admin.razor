@page "/admin"
@using PR1Blazor.ApiRequest
@inject NavigationManager Navigation
@inject UserService UserService
@using PR1Blazor.ApiRequest.Models
@using PR1Blazor.ApiRequest.Models.Services

<PageTitle>Админ</PageTitle>

<div class="container py-4 admin-page">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h3 class="mb-1">Панель администратора</h3>
            <p class="text-muted mb-0">Управление пользователями</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="GoToMovieAdmin">Управление фильмами</button>
            <button class="btn btn-primary" @onclick="AddNewUser">Добавить пользователя</button>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <h5 class="mb-3">Текущий администратор</h5>
            @if (UserService.CurrentUser?.user != null)
            {
                <div class="row g-3">
                    <div class="col-md-4"><strong>ID:</strong> @UserService.CurrentUser.user.id_User</div>
                    <div class="col-md-4"><strong>Логин:</strong> @UserService.CurrentUser.user.Login</div>
                    <div class="col-md-4"><strong>Имя:</strong> @UserService.CurrentUser.user.Name</div>
                    <div class="col-md-4">
                        <strong>Роль:</strong>
                        <span class="badge @(UserService.CurrentUser.user.RoleId == 1 ? "bg-danger" : "bg-secondary")">
                            @(UserService.CurrentUser.user.RoleId == 1 ? "Администратор" : "Пользователь")
                        </span>
                    </div>
                    <div class="col-12">
                        <strong>Описание:</strong> @(UserService.CurrentUser.user.Descrioption ?? "—")
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">Администратор не найден. Выполните вход.</div>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">Список пользователей</h5>
        </div>
        <div class="card-body p-0">
            @if (users == null)
            {
                <div class="p-4 d-flex align-items-center gap-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <span class="text-muted">Загружаем пользователей...</span>
                </div>
            }
            else if (users.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Логин</th>
                            <th>Имя</th>
                            <th>Описание</th>
                            <th>Роль</th>
                            <th class="pe-3">Действия</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in users)
                        {
                            <tr>
                                <td class="ps-3">@user.id_User</td>
                                <td>@user.Login</td>
                                <td>@(user.Name ?? "—")</td>
                                <td class="admin-description">@(user.Descrioption ?? "—")</td>
                                <td>
                                    <span class="badge @(user.RoleId == 1 ? "bg-danger" : "bg-secondary")">
                                        @(user.RoleId == 1 ? "Администратор" : "Пользователь")
                                    </span>
                                </td>
                                <td class="pe-3">
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditUser(user)">Изменить</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(user)">Удалить</button>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-secondary m-3 mb-0" role="alert">Пользователей нет.</div>
            }
        </div>
    </div>
</div>

@if (addModal)
{
    <div class="admin-modal-backdrop">
        <div class="admin-modal card shadow border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">@(editingUser.id_User > 0 ? "Изменить пользователя" : "Новый пользователь")</h5>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseAddModal">Закрыть</button>
                </div>

                @if (editingUser.id_User > 0)
                {
                    <div class="text-muted mb-3">ID: @editingUser.id_User</div>
                }

                <div class="mb-3">
                    <label class="form-label">Логин</label>
                    <input class="form-control" @bind="editingUser.Login" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Имя</label>
                    <input class="form-control" @bind="editingUser.Name" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Описание</label>
                    <textarea class="form-control" @bind="editingUser.Descrioption" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Пароль</label>
                    <input class="form-control" type="password" @bind="editingUser.Password" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Роль</label>
                    <select class="form-select" @bind="editingUser.RoleId">
                        <option value="2">Пользователь</option>
                        <option value="1">Администратор</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(addError))
                {
                    <div class="alert alert-danger py-2 mb-3">@addError</div>
                }

                <div class="d-flex justify-content-end gap-2">
                    <button class="btn btn-outline-secondary" @onclick="CloseAddModal">Отмена</button>
                    <button class="btn btn-primary" @onclick="SaveUser">Сохранить</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .admin-page .admin-description {
        max-width: 360px;
    }

    .admin-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        z-index: 1050;
    }

    .admin-modal {
        width: min(640px, 100%);
    }
</style>

@code {
    private List<UserDataShort> users;
    private UserDataShort editingUser = new UserDataShort();
    private bool addModal = false;
    private string addError = "";

    [Inject] private RequestApi _apiRequest { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await getAllUser();
    }

    private async Task getAllUser()
    {
        var userData = await _apiRequest.GetAllUserAsync();
        users = userData?.data?.users ?? new List<UserDataShort>();
        StateHasChanged();
    }

    // изменить
    private void EditUser(UserDataShort user)
    {
        editingUser = new UserDataShort
        {
            id_User = user.id_User,
            Login = user.Login,
            Name = user.Name,
            Descrioption = user.Descrioption,
            Password = "",
            RoleId = user.RoleId
        };
        addError = "";
        addModal = true;
    }

    private void AddNewUser()
    {
        editingUser = new UserDataShort
        {
            RoleId = 2  
        };
        addError = "";
        addModal = true;
    }

    //отмена
    private void CloseAddModal()
    {
        addModal = false;
        editingUser = new UserDataShort();
        addError = "";
    }

    private async Task SaveUser()
    {
        addError = "";
        if (string.IsNullOrWhiteSpace(editingUser.Login) || string.IsNullOrWhiteSpace(editingUser.Name))
        {
            addError = "Логин и Имя обязательны для заполнения!";
            return;
        }

        if (editingUser.id_User > 0)
        {
            var putUser = new UpdateUser
            {
                Id = editingUser.id_User,
                Login = editingUser.Login,
                Name = editingUser.Name,
                Descrioption = editingUser.Descrioption,
                Password = editingUser.Password
            };

            var result = await _apiRequest.UpdateUserAsync(putUser);

            if (result.status)
            {
                CloseAddModal();
                await getAllUser();
            }
            else
            {
                addError = result.message ?? "Ошибка обновления";
            }
        }
        else
        {
            var newUserReq = new UserShortReq
            {
                Name = editingUser.Name,
                Descrioption = editingUser.Descrioption,
                Password = editingUser.Password,
                Login = editingUser.Login,
                RoleId = editingUser.RoleId
            };

            var result = await _apiRequest.AddNewUser2(newUserReq);

            if (result.status)
            {
                CloseAddModal();
                await getAllUser();
            }
            else
            {
                addError = $"Ошибка создания: {result.message}";
            }
        }
    }

    private async Task DeleteUser(UserDataShort user)
    {
        await _apiRequest.DeleteUserAsync(user.id_User);
        await getAllUser();
    }

    private void GoToMovieAdmin()
    {
        Navigation.NavigateTo("/movieForAdmin");
    }
}