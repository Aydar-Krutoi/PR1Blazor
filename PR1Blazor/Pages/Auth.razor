@page "/"
@using PR1Blazor.ApiRequest
@using PR1Blazor.ApiRequest.Models
@using PR1Blazor.ApiRequest.Models.Services
@inject NavigationManager Navigation
@inject UserService UserService

<PageTitle>Вход в систему</PageTitle>

<h1>Вход в систему</h1>

<div class="d-flex justify-content-center align-items-center min-vh-100 bg-light">
    <div class="card shadow-lg border-0" style="max-width: 420px; width: 100%;">
        <div class="card-body p-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold text-primary">Вход в систему</h2>
                <p class="text-muted">Введите данные для авторизации</p>
            </div>

            <form>
                <div class="mb-4">
                    <label class="form-label fw-semibold" for="loginEmail">Email / Логин</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-envelope-fill text-primary"></i>
                        </span>
                        <input @bind="_authUser.LoginR"
                               id="loginEmail"
                               type="email"
                               class="form-control"
                               placeholder="example@company.ru"
                               maxlength="50"
                               required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold" for="loginPassword">Пароль</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-lock-fill text-primary"></i>
                        </span>
                        <input @bind="_authUser.PasswordR"
                               id="loginPassword"
                               type="password"
                               class="form-control"
                               placeholder="••••••••"
                               maxlength="30"
                               required />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 shadow-sm text-center mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @errorMessage
                    </div>
                }
                
                <div class="d-grid mb-4">
                    <button class="btn btn-primary btn-lg fw-semibold"
                            @onclick="AuthUser"
                            type="button">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        Войти
                    </button>
                </div>

                <div class="text-center">
                    <p class="mb-0 text-muted">
                        Нет аккаунта?
                        <a href="/registrarion" class="text-primary fw-semibold text-decoration-none">
                            Зарегистрироваться
                        </a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@code
{
    [Inject] private UserService _userService { get; set; }
    private AuthUser _authUser = new AuthUser();
    private string errorMessage = "";

    private async void AuthUser()
    {
        await _userService.LoadUserAsync(_authUser);
        if (UserService.CurrentUser != null && UserService.CurrentUser.status)
        {
            if (UserService.CurrentUser.user.RoleId == 1)
            {
                Navigation.NavigateTo("/admin");
            }
            else
            {
                Navigation.NavigateTo("/profile");
            }
        }
        else
        {
            errorMessage = "Неверный логин или пароль. Попробуйте снова.";
        }
    }
}
