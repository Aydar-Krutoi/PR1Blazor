@page "/movie/{Id:int}"
@using PR1Blazor.ApiRequest
@inject RequestApi RequestApi
@inject NavigationManager Navigation

<PageTitle>Детали фильма</PageTitle>

@if (isLoading)
{
    <p>Загрузка...</p>
}
else if (movie is null)
{
    <p>Фильм не найден.</p>
}
else
{
    <button class="btn btn-outline-secondary" @onclick="GoBack">Назад</button>

    <h3 class="mt-3">@movie.Name_Movie</h3>
    <img src="@movie.Url" alt="@movie.Name_Movie" width="220" />
    <p><b>Жанр:</b> @movie.Genre_Movie</p>
    <p><b>Дата выхода:</b> @movie.Release_Date.ToString("dd.MM.yyyy")</p>
    <p><b>Рейтинг:</b> @movie.Rating</p>
    <p><b>Описание:</b> @movie.Description_Movie</p>
}

@code {
    [Parameter] public int Id { get; set; }

    private PR1Blazor.ApiRequest.Models.Movie.MovieShortData? movie;
    private bool isLoading;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        var all = await RequestApi.GetMovieAsync();
        movie = all?.data?.movies?.FirstOrDefault(x => x.Id_Movie == Id);
        isLoading = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/movie");
    }
}